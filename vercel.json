{
  "cleanUrls": true,
  "redirects": [
    { "source": "/apresentacao", "destination": "/APRESENTACAO_ADMINISTRACAO.html", "permanent": false },
    { "source": "/resumo", "destination": "/docs.html?f=RESUMO_ADMINISTRACAO.md", "permanent": false },
    { "source": "/arquitetura", "destination": "/docs.html?f=ORDERS_V2_ARCHITECTURE.md", "permanent": false }
  ],
  "headers": [
    {
      "source": "/(.*).md",
      "headers": [
        { "key": "Content-Type", "value": "text/markdown; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=300" }
      ]
    },
    {
      "source": "/(.*).(html|css|js)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300" }
      ]
    }
  ]
}
